<configuration>
    <!-- Tạo một bộ in (appender) tên là STDOUT để in ra Console -->
    <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <!-- Quy định format: Giờ:Phút:Giây [Luồng] MỨC_ĐỘ - Tên Class: Lời nhắn -->
            <pattern>%d{HH:mm:ss} [%thread] %-5level %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- root level="debug" để bật mọi mức độ log (kể cả những log lặt vặt của DEBUG) -->
    <root level="debug">
        <appender-ref ref="STDOUT" />
    </root>
</configuration>
